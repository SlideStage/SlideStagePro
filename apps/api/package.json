{
  "name": "@slidestage/pro-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SlideStage Pro API server (Hono + Prisma + SQLite + Better Auth).",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "node scripts/ensure-root-symlinks.mjs",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run --reporter=verbose",
    "predb:generate": "node scripts/ensure-root-symlinks.mjs",
    "postdb:generate": "node scripts/ensure-root-symlinks.mjs",
    "db:generate": "node scripts/prisma-env.mjs generate --schema=../../prisma/schema.prisma",
    "db:migrate:dev": "node scripts/prisma-env.mjs migrate dev --schema=../../prisma/schema.prisma",
    "db:migrate": "node scripts/prisma-env.mjs migrate deploy --schema=../../prisma/schema.prisma",
    "db:studio": "node scripts/prisma-env.mjs studio --schema=../../prisma/schema.prisma",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.18.0",
    "@prisma/client": "^6.19.3",
    "@slidestage/core": "file:../../vendor/slidestage-core-0.1.0.tgz",
    "@slidestage/pro-shared": "workspace:*",
    "better-auth": "^1.4.0",
    "better-sqlite3": "^12.4.0",
    "fflate": "^0.8.2",
    "hono": "^4.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.7.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
