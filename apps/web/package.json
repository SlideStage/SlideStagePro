{
  "name": "@slidestage/pro-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SlideStage Pro web client (React 19 + Vite + react-router v7).",
  "scripts": {
    "sync:brand": "node scripts/sync-brand.mjs",
    "predev": "pnpm sync:brand",
    "prebuild": "pnpm sync:brand",
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@slidestage/brand": "^0.2.0",
    "@slidestage/core": "^0.1.1",
    "@slidestage/lite-preset": "^0.1.1",
    "@slidestage/pro-preset": "workspace:*",
    "@slidestage/pro-shared": "workspace:*",
    "@slidestage/ui": "^0.1.1",
    "better-auth": "^1.4.0",
    "fflate": "^0.8.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.10.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
