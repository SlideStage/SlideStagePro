DATABASE_URL="file:./dev.db"
PORT=4000
HOST=0.0.0.0
STORAGE_ROOT=./storage
LOG_LEVEL=info
WEB_ORIGIN=http://localhost:5173

# Upload limits (bytes) — see spec §2.5
MAX_UPLOAD_BYTES=209715200
MAX_DECOMPRESSED_BYTES=1073741824
MAX_FILE_BYTES=104857600
MAX_SLIDES=500

# Session cookies
# AUTH_COOKIE_SECURE=true
# AUTH_SESSION_DAYS=30
# AUTH_SESSION_COOKIE=slidestage_session

# /storage/* access tokens (HMAC-signed, deck-scoped). Sandboxed slide iframes
# run at an opaque origin so SameSite cookies don't ride along on their
# subresource fetches; these short-lived tokens fill that gap. Unset → server
# generates a fresh random secret per process (tokens invalidate on restart,
# which is fine for short TTLs but undesirable in prod). Set this in prod so
# live links survive restarts. See docs/bugs.md finding #20.
# AUTH_STORAGE_TOKEN_SECRET=<at-least-32-bytes-of-base64-or-hex>
# AUTH_STORAGE_TOKEN_TTL_SEC=3600

# Self-service registration master switch.
# When set to `false`, POST /api/auth/register returns 403 (EREGCLOSED) and
# OAuth / OIDC callbacks refuse to mint a new local user. The very first
# registration is still allowed (so the deployment can seed its bootstrap
# admin) — see docs/USER_MANAGEMENT.md for the full rules.
# Defaults to `true` to stay backwards-compatible with existing deployments.
AUTH_ALLOW_REGISTRATION=true
