// .stage Platform — Prisma schema (SQLite)
//
// Mirrors spec §5.5 (Postgres recommendation), adapted for SQLite by:
//  • storing JSON blobs as TEXT
//  • using TEXT primary keys instead of UUID native types
//  • dropping native ARRAY/JSONB; we serialize JSON with JSON.stringify

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Deck {
  // External-facing id is manifest.id (slug, ≤64 chars).
  // We also keep an opaque internal upload version so re-uploads don't clobber.
  id           String   @id
  ownerId      String
  schemaVer    String
  title        String
  subtitle     String?
  author       String?
  description  String?
  totalSlides  Int
  width        Int
  height       Int
  /// Full manifest.json as a JSON string.
  manifest     String
  /// Filesystem path (relative to STORAGE_ROOT) where the deck was unpacked.
  storageRoot  String
  sizeBytes    Int
  uploadedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  slides       Slide[]
  annotations  Annotation[]
  noteEdits    NoteEdit[]

  @@index([ownerId])
  @@map("decks")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  avatarUrl    String?
  passwordHash String?
  role         String    @default("user")
  disabledAt   DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  @@index([role])
  @@map("users")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String?
  displayName       String?
  avatarUrl         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
  @@map("accounts")
}

model Session {
  id         String   @id
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  userAgent  String?
  ip         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Slide {
  deckId    String
  idx       Int
  slideId   String
  label     String?
  filePath  String
  thumbPath String?
  notes     String?

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@id([deckId, idx])
  @@index([deckId])
  @@map("slides")
}

model Annotation {
  deckId    String
  userId    String
  slideIdx  Int
  /// JSON-serialized array of Stroke objects.
  strokes   String
  updatedAt DateTime @updatedAt

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@id([deckId, userId, slideIdx])
  @@index([deckId, userId])
  @@map("annotations")
}

/// Append-only edit log for owner-side speaker-note changes.
/// One row per (deckId, slideIdx) actually-changed by a single PATCH call.
model NoteEdit {
  id            Int      @id @default(autoincrement())
  deckId        String
  /// Editor's authenticated user id.
  userId        String
  /// 1-based slide index (matches manifest.slides[].index).
  slideIdx      Int
  /// `null` if the slot was previously empty.
  previousNotes String?
  /// `null` if the slot was cleared.
  newNotes      String?
  editedAt      DateTime @default(now())

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, editedAt])
  @@map("note_edits")
}
