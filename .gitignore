# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Accidental tsc emit alongside .ts test sources (vitest reads .ts directly).
# Keep .test.ts sources but ignore any .test.js compiled from them.
apps/api/tests/**/*.js
apps/web/tests/**/*.js

# Coverage / test artifacts
coverage/
.nyc_output/
test-results/
playwright-report/
e2e-storage/

# Environment & secrets
.env
.env.local
.env.*.local

# SQLite / runtime data
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
data/
storage/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / IDE
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Playwright browser cache (project-local)
.pw-browsers/

# Editor temp
*.swp
*.swo
*~

# Vendor tarball sources kept (tarballs themselves are committed)
# do NOT ignore vendor/*.tgz
