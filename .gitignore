# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Accidental tsc emit alongside .ts test sources (vitest reads .ts directly).
# Keep .test.ts sources but ignore any .test.js compiled from them.
apps/api/tests/**/*.js
apps/web/tests/**/*.js

# Coverage / test artifacts
coverage/
.nyc_output/
test-results/
playwright-report/
e2e-storage/

# Brand assets mirrored from @slidestage/brand (regenerated by
# `pnpm --filter @slidestage/pro-web sync:brand`, auto-invoked via
# predev/prebuild). The npm package is the source of truth.
apps/web/public/brand/

# Environment & secrets
.env
.env.local
.env.*.local

# SQLite / runtime data
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
# Anchor `data/` and `storage/` to repo root — without the leading slash
# they also match `apps/api/src/storage/` (a real source directory).
/data/
/storage/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / IDE
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Playwright browser cache (project-local)
.pw-browsers/

# Editor temp
*.swp
*.swo
*~
