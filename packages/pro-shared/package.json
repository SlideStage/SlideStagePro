{
  "name": "@slidestage/pro-shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pro-internal shared types and constants. Consumed by @slidestage/pro-api, @slidestage/pro-web, @slidestage/pro-preset.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests yet' && exit 0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
