{
  "name": "@slidestage/pro-preset",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pro-only plugin preset for SlideStage. Wires Pro capabilities into a SlideStage instance.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests yet' && exit 0"
  },
  "dependencies": {
    "@slidestage/core": "^0.1.1",
    "@slidestage/pro-shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
