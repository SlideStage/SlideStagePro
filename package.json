{
  "name": "slidestage-pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SlideStage Pro: self-hosted .stage platform built on Prisma + SQLite + Hono + React.",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm -r --filter \"./apps/*\" build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "pnpm check:boundaries && pnpm typecheck && pnpm test && pnpm build",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "sync:vendor": "node scripts/sync-vendor.mjs",
    "db:generate": "pnpm --filter @slidestage/pro-api db:generate",
    "db:migrate": "pnpm --filter @slidestage/pro-api db:migrate",
    "db:migrate:dev": "pnpm --filter @slidestage/pro-api db:migrate:dev",
    "db:seed": "pnpm --filter @slidestage/pro-api db:seed",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  }
}
