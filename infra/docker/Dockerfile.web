# syntax=docker/dockerfile:1.7
#
# SlideStagePro Web — React 19 + Vite static bundle served by nginx
#
# Build context: monorepo ROOT (Lite @slidestage/* deps come from the public
# npm registry, resolved during `pnpm install` below).
#
#   docker build -f infra/docker/Dockerfile.web -t slidestage-pro/web .
#
# Multi-stage:
#   builder — pnpm install + vite build → /app/apps/web/dist
#   runtime — nginx:alpine serving the static bundle (SPA fallback)

ARG NODE_VERSION=22.20.0
ARG PNPM_VERSION=11.1.3

# ─── builder ─────────────────────────────────────────────────────────────────
FROM node:${NODE_VERSION}-alpine AS builder
ENV PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH \
    CI=true
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate
WORKDIR /app

# Workspace manifests (cache-friendly layer; @slidestage/* are fetched from npm).
COPY pnpm-workspace.yaml pnpm-lock.yaml .npmrc package.json ./
COPY apps/api/package.json ./apps/api/package.json
COPY apps/web/package.json ./apps/web/package.json
COPY packages/pro-preset/package.json ./packages/pro-preset/package.json
COPY packages/pro-shared/package.json ./packages/pro-shared/package.json

# The Web build needs apps/api/scripts/ensure-root-symlinks.mjs to exist
# during install (api's postinstall hook runs against the whole workspace).
COPY apps/api/scripts ./apps/api/scripts

# The web build doesn't need prisma generate or better-sqlite3 to compile.
# --ignore-scripts skips both postinstall hooks (incl. apps/api/scripts/
# ensure-root-symlinks.mjs, which would fail without Prisma artifacts) and
# native build scripts. The web bundle itself doesn't pull these symbols.
RUN --mount=type=cache,id=pnpm-store-web,target=/pnpm/store \
    pnpm install --frozen-lockfile --prefer-offline --ignore-scripts

# Now copy actual sources and build pro-shared/pro-preset/web in order.
COPY tsconfig.base.json ./tsconfig.base.json
COPY packages/pro-shared ./packages/pro-shared
COPY packages/pro-preset ./packages/pro-preset
COPY apps/web ./apps/web

RUN pnpm --filter @slidestage/pro-shared build \
 && pnpm --filter @slidestage/pro-preset build \
 && pnpm --filter @slidestage/pro-web build

# ─── runtime ─────────────────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# SPA-only config: serve the Vite bundle on :8080 with history fallback.
# The edge nginx (defined in docker-compose) reverse-proxies / to web:8080
# and /api/ to api:3000, so this internal nginx never handles /api.
COPY infra/nginx/spa.conf /etc/nginx/conf.d/default.conf

# Bundle from vite. The build emits index.html + assets/ at the project root.
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget -qO- "http://127.0.0.1:8080/" >/dev/null || exit 1
