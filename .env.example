# ---- Database ----
# SQLite file path. In Docker this is mounted to /data; in local dev use ./data/
DATABASE_URL="file:./data/slidestage-pro.sqlite"

# ---- Storage ----
# Storage driver: 'local' for filesystem. S3/MinIO reserved for future.
STORAGE_DRIVER=local
# Root directory for storage driver=local; .stage files land here.
DATA_DIR=./data

# ---- API Server ----
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ---- Better Auth ----
# Generate via: openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_ME_WITH_32_BYTE_BASE64_SECRET"
# Public URL Better Auth uses to build session cookies / callback URLs
BETTER_AUTH_URL="http://localhost:3000"

# ---- Bootstrap admin (created on first boot if no user exists) ----
# Required for first deploy; can be removed after bootstrap.
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="ChangeMeOnFirstLogin!"
BOOTSTRAP_ADMIN_NAME="Admin"

# ---- Upload ----
UPLOAD_MAX_BYTES=104857600

# ---- CORS (comma-separated origins; '*' is unsafe in prod) ----
CORS_ORIGINS="http://localhost:5173,http://localhost"
